FROM python:3.10

WORKDIR /app

# Copy entire project including root files
COPY . .

# Install dependencies from root requirements.txt
RUN pip install -r requirements.txt

EXPOSE 7860

# Run from root directory so imports work correctly
CMD ["sh", "-c", "cd /app && uvicorn server.app:app --host 0.0.0.0 --port 7860 --timeout-keep-alive 60 --access-log"]